<mujoco model="luxo_lamp">
  <compiler angle="degree" autolimits="true"/>

  <option gravity="0 0 -9.81" timestep="0.002"/>

  <default>
    <joint damping="2.0" armature="0.01"/>
    <geom condim="3" friction="1.0 0.005 0.001"/>
    <motor ctrlrange="-15 15" ctrllimited="true"/>
  </default>

  <asset>
    <texture type="2d" name="grid" builtin="checker" width="512" height="512"
             rgb1="0.2 0.3 0.4" rgb2="0.3 0.4 0.5"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance="0.2"/>
    <material name="base_mat" rgba="0.85 0.85 0.82 1"/>
    <material name="arm_mat" rgba="0.9 0.9 0.88 1"/>
    <material name="head_mat" rgba="0.92 0.90 0.85 1"/>
    <material name="link_mat" rgba="0.82 0.82 0.80 1"/>
    <material name="spring_mat" rgba="0.55 0.55 0.55 1"/>
    <material name="joint_mat" rgba="0.5 0.5 0.5 1"/>
    <material name="bulb_mat" rgba="1 1 0.85 0.9"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <geom type="plane" size="2 2 0.01" material="grid"/>
    <light pos="0 -0.8 1.5" dir="0 0.5 -1" diffuse="0.9 0.9 0.9"/>
    <light pos="0.8 0.5 1.5" dir="-0.5 -0.5 -1" diffuse="0.5 0.5 0.5"/>

    <!-- === LAMP BASE === -->
    <body name="base" pos="0 0 0.012">
      <geom name="base_plate" type="cylinder" size="0.07 0.012" mass="2.0" material="base_mat"/>
      <geom name="base_dome" type="cylinder" pos="0 0 0.012" size="0.03 0.006" mass="0.1"
            material="base_mat"/>
      <joint name="base_yaw" type="hinge" axis="0 0 1" range="-180 180"
             stiffness="15" springref="0" damping="5"/>

      <!-- === LOWER ARM ASSEMBLY === -->
      <body name="lower_arm" pos="0 0 0.018">
        <!-- Joint pin -->
        <geom name="lower_pivot" type="cylinder" size="0.007 0.016" euler="90 0 0"
              mass="0.02" material="joint_mat"/>

        <!-- Lower arm: ~45deg from vertical at rest -->
        <joint name="lower_arm_pitch" type="hinge" axis="0 1 0" range="-10 110"
               stiffness="80" springref="45" damping="5"/>

        <!-- Front link -->
        <geom name="lower_front" type="box" pos="0.01 0 0.08" size="0.005 0.003 0.08"
              mass="0.04" material="arm_mat"/>
        <!-- Rear link -->
        <geom name="lower_rear" type="box" pos="-0.01 0 0.08" size="0.005 0.003 0.08"
              mass="0.04" material="arm_mat"/>
        <!-- Bottom brace -->
        <geom name="lower_brace_bot" type="box" pos="0 0 0.008" size="0.015 0.003 0.003"
              mass="0.005" material="link_mat"/>
        <!-- Top brace -->
        <geom name="lower_brace_top" type="box" pos="0 0 0.152" size="0.015 0.003 0.003"
              mass="0.005" material="link_mat"/>
        <!-- Spring -->
        <geom name="spring" type="cylinder" pos="0 0 0.08" size="0.004 0.05"
              mass="0.03" material="spring_mat"/>

        <!-- === UPPER ARM ASSEMBLY === -->
        <body name="upper_arm" pos="0 0 0.16">
          <!-- Joint pin -->
          <geom name="upper_pivot" type="cylinder" size="0.007 0.016" euler="90 0 0"
                mass="0.02" material="joint_mat"/>

          <!-- Upper arm folds back to create Z. springref=-100 -->
          <joint name="upper_arm_pitch" type="hinge" axis="0 1 0" range="-150 10"
                 stiffness="65" springref="-100" damping="5"/>

          <!-- Front link -->
          <geom name="upper_front" type="box" pos="0.01 0 0.07" size="0.005 0.003 0.07"
                mass="0.035" material="arm_mat"/>
          <!-- Rear link -->
          <geom name="upper_rear" type="box" pos="-0.01 0 0.07" size="0.005 0.003 0.07"
                mass="0.035" material="arm_mat"/>
          <!-- Bottom brace -->
          <geom name="upper_brace_bot" type="box" pos="0 0 0.008" size="0.015 0.003 0.003"
                mass="0.005" material="link_mat"/>
          <!-- Top brace -->
          <geom name="upper_brace_top" type="box" pos="0 0 0.132" size="0.015 0.003 0.003"
                mass="0.005" material="link_mat"/>

          <!-- === HEAD === -->
          <body name="head" pos="0 0 0.14">
            <!-- Joint pin -->
            <geom name="head_pivot" type="cylinder" size="0.005 0.013" euler="90 0 0"
                  mass="0.01" material="joint_mat"/>

            <!-- Head spring to keep shade pointing forward/down -->
            <joint name="head_tilt" type="hinge" axis="0 1 0" range="-90 90"
                   stiffness="30" springref="55" damping="2"/>

            <!-- Neck -->
            <geom name="neck" type="box" pos="0.012 0 0" size="0.012 0.003 0.005"
                  mass="0.01" material="arm_mat"/>

            <!-- === SHADE (cone) === -->
            <!-- Inner narrow -->
            <geom name="shade_base" type="cylinder" pos="0.035 0 -0.005" euler="0 75 0"
                  size="0.018 0.007" mass="0.015" material="head_mat"/>
            <!-- Mid -->
            <geom name="shade_mid" type="cylinder" pos="0.055 0 -0.015" euler="0 75 0"
                  size="0.032 0.009" mass="0.025" material="head_mat"/>
            <!-- Outer wide -->
            <geom name="shade_outer" type="cylinder" pos="0.075 0 -0.025" euler="0 75 0"
                  size="0.045 0.009" mass="0.035" material="head_mat"/>
            <!-- Rim -->
            <geom name="shade_rim" type="cylinder" pos="0.09 0 -0.032" euler="0 75 0"
                  size="0.055 0.003" mass="0.015" material="head_mat"/>

            <!-- Bulb -->
            <geom name="bulb" type="sphere" pos="0.06 0 -0.018" size="0.01"
                  mass="0.005" material="bulb_mat"/>

            <!-- Shade light -->
            <light pos="0.065 0 -0.02" dir="0.5 0 -0.8" diffuse="0.4 0.4 0.3"
                   cutoff="60" exponent="20"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="base_yaw_motor" joint="base_yaw" gear="5"/>
    <motor name="lower_arm_motor" joint="lower_arm_pitch" gear="10"/>
    <motor name="upper_arm_motor" joint="upper_arm_pitch" gear="8"/>
    <motor name="head_tilt_motor" joint="head_tilt" gear="4"/>
  </actuator>

  <sensor>
    <jointpos name="base_yaw_pos" joint="base_yaw"/>
    <jointpos name="lower_arm_pos" joint="lower_arm_pitch"/>
    <jointpos name="upper_arm_pos" joint="upper_arm_pitch"/>
    <jointpos name="head_tilt_pos" joint="head_tilt"/>
    <jointvel name="base_yaw_vel" joint="base_yaw"/>
    <jointvel name="lower_arm_vel" joint="lower_arm_pitch"/>
    <jointvel name="upper_arm_vel" joint="upper_arm_pitch"/>
    <jointvel name="head_tilt_vel" joint="head_tilt"/>
  </sensor>
</mujoco>
